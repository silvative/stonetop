<div class="tab details" data-group="primary" data-tab="details">
	<section class="sheet-tab">

		{{> "stonetop.choice-section" groups=stonetop.playbook.lore cgContext="lore"}}

		{{#if stonetop.playbook.background.options.length}}
		<div class="details-section">
			{{> "stonetop.section-heading" title=(localize "stonetop.character.selection.background.label") note=(localize "stonetop.character.selection.chooseOne")}}
			{{#each stonetop.playbook.background.options}}
			<label class="stonetop-item{{#if selected}} is-checked{{/if}}">
				<div class="stonetop-item-header">
					<input type="radio" class="stonetop-item-check" name="stonetop-background"
					       value="{{slug}}"{{#if selected}} checked{{/if}}>
					<strong class="stonetop-item-name">{{label}}</strong>
				</div>
				{{#if description}}
				<div class="stonetop-item-description">{{{description}}}</div>
				{{/if}}
			</label>
			{{#if (and selected choices)}}
			<div class="stonetop-bg-choices">
				<p class="stonetop-bg-choices-label">{{choices.label}} (choose {{choices.countLabel}})</p>
				{{#each choices.options}}
				<label class="stonetop-bg-choice-option">
					<input type="checkbox" class="stonetop-item-check stonetop-bg-choice"
					       data-slug="{{slug}}"
					       {{#if checked}}checked{{/if}}>
					{{label}}
				</label>
				{{/each}}
			</div>
			{{/if}}
			{{/each}}
		</div>
		{{/if}}

		{{#if stonetop.playbook}}
		<div class="details-section">
			{{> "stonetop.section-heading" title=(localize "stonetop.character.selection.instinct.label") note=(localize "stonetop.character.selection.chooseOne")}}
			<input type="text" class="stonetop-instinct-custom"
			       value="{{stonetop.playbook.instinct.selected}}"
			       placeholder="{{localize "stonetop.character.selection.instinct.customPlaceholder"}}">
			{{#if stonetop.playbook.instinct.group}}
			<div class="stonetop-instinct-options">
				{{#each stonetop.playbook.instinct.group.list}}
				{{> "stonetop.choice-row" radio=true namePrefix="stonetop-instinct" cgContext="instinct"}}
				{{/each}}
			</div>
			{{/if}}
		</div>
		{{/if}}

		{{#if stonetop.playbook.appearance.length}}
		<div class="details-section">
			{{> "stonetop.section-heading" title=(localize "stonetop.character.selection.appearance.label") note=(localize "stonetop.character.selection.appearance.instruction")}}
			{{#each stonetop.playbook.appearance}}
			{{> "stonetop.choice-row" cgContext="appearance" namePrefix="stonetop-appearance"}}
			{{/each}}
		</div>
		{{/if}}

		{{#if stonetop.playbook.origin.options.length}}
		<div class="details-section">
			{{> "stonetop.section-heading" title=(localize "stonetop.character.selection.origin.label") note=(localize "stonetop.character.selection.origin.instruction")}}
			{{#each stonetop.playbook.origin.options}}
			<div class="stonetop-origin-option{{#if selected}} selected{{/if}}">
				<label class="stonetop-origin-region">
					<input type="radio" class="stonetop-item-check" name="stonetop-origin"
					       value="{{region}}"{{#if selected}} checked{{/if}}>
					<strong>{{region}}</strong>
				</label>
				<div class="stonetop-origin-names">
					{{#each names}}
					<button type="button" class="stonetop-origin-name">{{this}}</button>
					{{/each}}
				</div>
			</div>
			{{/each}}
		</div>
		{{/if}}

	</section>
</div>

{
	"$schema": "https://json.schemastore.org/foundryvtt-module-manifest.json",
	"id": "stonetop",
	"title": "Stonetop",
	"description": "An unofficial module for playing Stonetop in Foundry VTT.",
	"version": "0.2.0",
	"compatibility": {
		"minimum": "11",
		"verified": "12"
	},
	"relationships": {
		"systems": [
			{
				"id": "pbta",
				"type": "system",
				"compatibility": {
					"verified": "1.1.1"
				}
			}
		]
	},
	"authors": [
		{
			"name": "aMediocerDad",
			"flags": {}
		},
		{
			"name": "taylor-nightingale"
		}
	],
	"flags": {
		"hotReload": {
			"extensions": ["css", "js", "hbs", "json"],
			"paths": [
				"stonetop.js",
				"module",
				"templates",
				"styles",
				"languages"
			]
		}
	},
	"esmodules": [
		"stonetop.js"
	],
	"styles": [
		"styles/stonetop.css"
	],
	"languages": [
		{
			"lang": "en",
			"name": "English",
			"path": "languages/en.json"
		}
	],
	"packs": [
		{
			"name": "basic-moves",
			"label": "Basic Moves",
			"path": "packs/basic-moves",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "playbooks",
			"label": "Playbooks",
			"path": "packs/playbooks",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "special-moves",
			"label": "Special Moves",
			"path": "packs/special-moves",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "playbook-moves",
			"label": "Playbook Moves",
			"path": "packs/playbook-moves",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "follower-moves",
			"label": "Follower Moves",
			"path": "packs/follower-moves",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "homefront-moves",
			"label": "Homefront Moves",
			"path": "packs/homefront-moves",
			"type": "Item",
			"system": "pbta"
		}
	],
	"url": "https://github.com/taylor-nightingale/stonetop",
	"license": "LICENSE",
	"manifest": "https://raw.githubusercontent.com/taylor-nightingale/stonetop/main/module.json",
	"download": "https://github.com/taylor-nightingale/stonetop/archive/refs/heads/main.zip"
}

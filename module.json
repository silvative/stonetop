{
	"$schema": "https://json.schemastore.org/foundryvtt-module-manifest.json",
	"id": "stonetop",
	"title": "Stonetop",
	"description": "An unofficial module for playing Stonetop in Foundry VTT.",
	"version": "0.8.0",
	"compatibility": {
		"minimum": "12",
		"verified": "14"
	},
	"relationships": {
		"systems": [
			{
				"id": "pbta",
				"type": "system",
				"compatibility": {
					"minimum": "1.1.1",
					"verified": "1.2.0"
				}
			}
		]
	},
	"authors": [
		{
			"name": "aMediocerDad",
			"flags": {}
		},
		{
			"name": "taylor-nightingale"
		}
	],
	"flags": {
		"hotReload": {
			"extensions": ["css", "js", "hbs", "json"],
			"paths": [
				"stonetop.js",
				"module",
				"styles",
				"languages",
				"templates"
			]
		}
	},
	"esmodules": [
		"stonetop.js"
	],
	"styles": [
		"styles/stonetop.css"
	],
	"languages": [
		{
			"lang": "en",
			"name": "English",
			"path": "languages/en.json"
		}
	],
	"documentTypes": {
		"Actor": {
			"steading": {}
		}
	},
	"packs": [
		{
			"name": "basic-moves",
			"label": "Basic Moves",
			"path": "packs/basic-moves",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "playbooks",
			"label": "Playbooks",
			"path": "packs/playbooks",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "special-moves",
			"label": "Special Moves",
			"path": "packs/special-moves",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "playbook-moves",
			"label": "Playbook Moves",
			"path": "packs/playbook-moves",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "follower-moves",
			"label": "Follower Moves",
			"path": "packs/follower-moves",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "homefront-moves",
			"label": "Homefront Moves",
			"path": "packs/homefront-moves",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "outfit-items",
			"label": "Inventory Items",
			"path": "packs/outfit-items",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "arcana",
			"label": "Arcana",
			"path": "packs/arcana",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "post-death-inserts",
			"label": "Post-Death Inserts",
			"path": "packs/post-death-inserts",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "post-death-moves",
			"label": "Post-Death Moves",
			"path": "packs/post-death-moves",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "followers",
			"label": "Followers",
			"path": "packs/followers",
			"type": "Item",
			"system": "pbta"
		},
		{
			"name": "steading-improvements",
			"label": "Steading Improvements",
			"path": "packs/steading-improvements",
			"type": "Item",
			"system": "pbta"
		}
	],
	"url": "https://github.com/taylor-nightingale/stonetop",
	"license": "LICENSE",
	"manifest": "https://github.com/taylor-nightingale/stonetop/releases/latest/download/module.json",
	"download": "https://github.com/taylor-nightingale/stonetop/archive/refs/heads/main.zip"
}
